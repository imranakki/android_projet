<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Night theme — inherits everything from day theme (always dark) -->
    <style name="Theme.Projet_android" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">#6A3DE8</item>
        <item name="colorPrimaryVariant">#4A20C8</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorSecondary">#9B59FF</item>
        <item name="colorSecondaryVariant">#7C3DDD</item>
        <item name="colorOnSecondary">#FFFFFF</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">false</item>
        <item name="android:windowBackground">@drawable/gradient_background</item>
        <item name="android:textColorHint">#FFFFFF</item>
        <item name="textInputStyle">@style/Widget.App.TextInputLayout</item>
    </style>
</resources>